{
	"name": "healthwatchifier",
	"version": "5.0.0",
	"description": "A Cloudflare Workers web app that re-formats health news articles for frictionless sharing",
	"main": "src/index.js",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"format": "prettier --write '**/*.{js,css,json,md}'",
		"lint": "eslint src/",
		"prepare": "husky install"
	},
	"keywords": [
		"health",
		"news",
		"social-media",
		"cloudflare-workers",
		"canada"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"eslint": "^8.57.0",
		"husky": "^9.0.11",
		"lint-staged": "^15.2.2",
		"prettier": "^3.2.5",
		"wrangler": "^4.23.0"
	},
	"lint-staged": {
		"*.{js,css,json,md}": [
			"prettier --write"
		],
		"*.js": [
			"eslint --fix"
		]
	},
	"dependencies": {
		"node-fetch": "^3.3.2"
	}
}
